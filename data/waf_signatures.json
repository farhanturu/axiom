{
  "cloudflare": {
    "name": "Cloudflare",
    "headers": {"server": "cloudflare", "cf-ray": null},
    "cookies": ["__cfduid", "__cf_bm"],
    "response_code": [503, 403],
    "body_patterns": ["Attention Required!|Cloudflare Ray ID:", "Just a moment...", "Checking your browser before accessing"]
  },
  "aws_waf": {
    "name": "AWS WAF",
    "headers": {"x-amzn-RequestId": null, "x-amzn-ErrorType": null},
    "cookies": ["aws-waf-token"],
    "response_code": [403],
    "body_patterns": ["Request blocked", "403 Forbidden", "AWS WAF"]
  },
  "imperva": {
    "name": "Imperva Incapsula",
    "headers": {"x-iinfo": null, "x-cdn": "Incapsula"},
    "cookies": ["incap_ses_", "visid_incap_"],
    "response_code": [403, 509],
    "body_patterns": ["Incapsula incident", "_incapsula_resource", "Blocked because of security"]
  },
  "akamai": {
    "name": "Akamai",
    "headers": {"x-akamai-request-id": null, "x-akamai-transformed": null},
    "cookies": ["ak_bmsc", "bm_sz", "_abck"],
    "response_code": [403],
    "body_patterns": ["AkamaiGHost", "Reference #[0-9]+\\.[0-9a-f]+\\.[0-9a-f]+"]
  },
  "f5_bigip": {
    "name": "F5 BIG-IP ASM",
    "headers": {"x-asm-version": null, "x-wa-ident": null},
    "cookies": ["TS", "BIGipServer"],
    "response_code": [403, 200],
    "body_patterns": ["The requested URL was rejected", "Support ID", "F5 Networks"]
  },
  "modsecurity": {
    "name": "ModSecurity",
    "headers": {"x-modsecurity": null},
    "cookies": [],
    "response_code": [403, 406, 500],
    "body_patterns": ["ModSecurity", "This error was generated by ModSecurity", "Not Acceptable"]
  },
  "sucuri": {
    "name": "Sucuri CloudProxy",
    "headers": {"x-sucuri-id": null, "x-sucuri-cache": null},
    "cookies": ["sucuri_cloudproxy"],
    "response_code": [403],
    "body_patterns": ["Sucuri WebSite Firewall", "cloudproxy@sucuri.net", "Access Denied - Sucuri"]
  },
  "barracuda": {
    "name": "Barracuda WAF",
    "headers": {"x-barracuda": null},
    "cookies": ["barra_counter_session"],
    "response_code": [403],
    "body_patterns": ["Barracuda WAF", "barracuda_net"]
  },
  "fortinet": {
    "name": "Fortinet FortiWeb",
    "headers": {"x-fortiweb": null},
    "cookies": [],
    "response_code": [403, 503],
    "body_patterns": ["FortiWeb", "fgd_icon", "Powered by Fortinet"]
  },
  "stackpath": {
    "name": "StackPath",
    "headers": {"x-stackpath-id": null},
    "cookies": ["sp_session"],
    "response_code": [403],
    "body_patterns": ["StackPath", "cdn.stackpath.com"]
  }
}
